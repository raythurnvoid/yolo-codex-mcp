{
	"name": "yolo-codex-mcp",
	"version": "0.0.0",
	"description": "Custom stdio MCP server that exposes the Smart Cheap Agent wrapper around Codex CLI tools for host-driven execution.",
	"keywords": [],
	"license": "ISC",
	"author": "",
	"bin": {
		"yolo-codex-mcp": "./dist/server.mjs"
	},
	"type": "module",
	"main": "dist/server.mjs",
	"scripts": {
		"build": "vp pack",
		"start": "node src/server.ts",
		"dev": "node --watch src/server.ts",
		"start:dist": "node dist/server.mjs",
		"format": "node ./node_modules/prettier/bin/prettier.cjs --write .",
		"format:check": "node ./node_modules/prettier/bin/prettier.cjs --check .",
		"check": "pnpm run format:check && vp check --no-fmt",
		"check:fix": "pnpm run format && vp check --fix --no-fmt",
		"test": "node --test --test-concurrency=1 tests/proxy.test.ts"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.28.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"vite-plus": "^0.1.14"
	},
	"packageManager": "pnpm@10.28.0"
}
